<Window x:Class="DemoExamen2026.AddEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExamen2026"
        mc:Ignorable="d"
        Title="AddEditWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Артикул:" VerticalAlignment="Center"/>
        <TextBox x:Name="ArticuleBox" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Продукт:" VerticalAlignment="Center"/>
        <ComboBox x:Name="ProductCombo" Grid.Row="1" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Product" SelectedValuePath="ID"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Категория:" VerticalAlignment="Center"/>
        <ComboBox x:Name="CategoryCombo" Grid.Row="2" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Category" SelectedValuePath="ID"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Производитель:" VerticalAlignment="Center"/>
        <ComboBox x:Name="ManufacturerCombo" Grid.Row="3" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Manufacturer" SelectedValuePath="ID"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Поставщик:" VerticalAlignment="Center"/>
        <ComboBox x:Name="ProviderCombo" Grid.Row="4" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Provider" SelectedValuePath="ID"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ед. измерения:" VerticalAlignment="Center"/>
        <ComboBox x:Name="MeasurementCombo" Grid.Row="5" Grid.Column="1" Margin="5"
                  DisplayMemberPath="Measurement" SelectedValuePath="ID"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Цена:" VerticalAlignment="Center"/>
        <TextBox x:Name="PriceBox" Grid.Row="6" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Скидка (%):" VerticalAlignment="Center"/>
        <TextBox x:Name="DiscountBox" Grid.Row="7" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Количество:" VerticalAlignment="Center"/>
        <TextBox x:Name="CountBox" Grid.Row="8" Grid.Column="1" Margin="5"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Комментарий:" VerticalAlignment="Top"/>
        <TextBox x:Name="CommentaryBox" Grid.Row="9" Grid.Column="1" Margin="5" Height="60" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="10" Grid.Column="0" Text="Фото:" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <TextBox x:Name="PhotoBox" Width="200" Margin="0,0,5,0"/>
            <Button Content="Обзор..." Click="BrowsePhoto_Click" Width="70"/>
        </StackPanel>

        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="80" Margin="5" Click="SaveButton_Click"/>
            <Button Content="Отмена" Width="80" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
