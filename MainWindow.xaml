<Window x:Class="DemoExamen2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExamen2026"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        Title="Вход" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" Background="#EEE"> 
            <TextBlock Margin="60 10">Вход</TextBlock>
            <TextBox x:Name="Login_Box" Margin="10"></TextBox>
            <PasswordBox x:Name="Password_Box" Margin="10"></PasswordBox>
            <Button x:Name="Button_Login" Margin="10" Content="Вход" Click="Button_Login_Click"/>
            <TextBlock x:Name="User_Another" Margin="10" MouseLeftButtonDown="User_Another_MouseLeftButtonDown">Вход</TextBlock>
        </StackPanel>
    </Grid>
</Window>
